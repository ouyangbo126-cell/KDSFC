Please complete only the values inside square brackets [ ]. Follow these strict rules:
- If any detail is not visible or cannot be confidently determined, write: unknown
- For ship length and deck width: use integer meters (±5 m error allowed)
- Hull number is typically a pure number (e.g., 68 for CVN-68).
- Confidence values must be in [0.00, 1.00], rounded to two decimal places
- Identification: Only select ship IDs from the provided 60 categories (e.g., CN-CV16, US-CV10, etc.). Do not use IDs outside of this list.
Output format:
(vessel,
    overall_appearance,
        deck_type: [angled deck | full-length deck | helicopter platform | unknown],
        island_location: [e.g., starboard midship | starboard stern | dual island | unknown],
        estimated_length_m: [integer meters or unknown],
        estimated_width_m: [integer meters or unknown]
        // Example:
        // deck_type: full-length deck
        // island_location: starboard midship
        // estimated_length_m: 240
        // estimated_deck_width_m: 38
)
(vessel,
    detailed_configuration,
        hull_number_location: [e.g., bow | stern | starboard | unknown],
        hull_number: [visible number | unknown],
        number_of_elevators: [integer | unknown],
        elevator_location: [e.g., forward of island, left side | forward of island, right side | unknown | or other valid descriptions]
        helicopter_platform_distribution: [e.g., side, left | side, right | unknown | or other valid descriptions]
        embarked_aircraft_model: [specific model or unknown],
        // Example:
        // hull_number_location: bow
        // hull_number: 550
        // number_of_elevators: 2
        // elevator_location: forward of island
        // helicopter_platform_distribution: front
        // embarked_aircraft_model: J-15
)
(vessel,
    surrounding_environment,
        cloud_coverage: [dense | sparse | none | unknown],
        surrounding_facilities: [dry dock | exhibition area | naval base | open sea | unknown]
        // Example:
        // cloud_coverage: none
        // surrounding_facilities: naval base
)
(vessel,
    overall_assessment_top3,
        identification_1: [ship_id], confidence_1: [0.00–1.00],
        identification_2: [ship_id], confidence_2: [0.00–1.00],
        identification_3: [ship_id], confidence_3: [0.00–1.00]
        // Example:
        // identification_1: [Aircraft Carriers][Essex class][US-CV10], confidence_1: 0.55
        // identification_2: [Aircraft Carriers][Kitty Hawk class][US-CV63], confidence_2: 0.35
        // identification_3: [Amphibious Assault][Wasp class][US-LHD1], confidence_3: 0.10
)
